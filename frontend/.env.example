VITE_API_BASE_URL=http://localhost:5112/api
# Production backend (Railway)
# VITE_API_BASE_URL=https://your-railway-service.up.railway.app/api
# Set this in Vercel for production so frontend targets your current Railway backend.
# Optional explicit fallback used when VITE_API_BASE_URL is missing.
# Leave blank to use same-origin /api (recommended for Vercel rewrite proxy).
VITE_FALLBACK_API_BASE_URL=
VITE_DEV_API_PROXY=http://localhost:5112
VITE_BASE_PATH=/
